parameters:
    level: 8
    paths:
        - src
        - tests
    bootstrapFiles:
        - tests/bootstrap-phpstan.php
    excludePaths:
        - vendor
    checkMissingIterableValueType: true
    checkGenericClassInNonGenericObjectType: true
    treatPhpDocTypesAsCertain: true
    reportUnmatchedIgnoredErrors: true
    scanFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
    ignoreErrors:
        # wpdb::prepare() n'accepte pas de chaînes dynamiques (table name) — pattern WP standard
        - message: '#Parameter \#1 \$query of method wpdb::prepare\(\) expects literal\-string#'
          path: src/Seo/RedirectModel.php
        # Propriétés des stubs wpdb dans les tests — aliasées par référence, invisible à PHPStan
        - message: '#Property class@anonymous.* is never read, only written#'
          path: tests/Unit/Seo/RedirectModelTest.php
        # Tableau générique dans le constructeur des stubs anonymes de test
        - message: '#has parameter \$insertCalls with no value type specified in iterable type array#'
          path: tests/Unit/Seo/RedirectModelTest.php
