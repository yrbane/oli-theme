[# Bannière du site (image + titre cliquable).
   Variables attendues:
     - homeUrl  (string)
     - siteName (string)
#]
<div class="banner" data-banner>
    <a class="banner__home" href="[[ homeUrl ]]" aria-label="[[ siteName ]] — accueil">
        <span class="banner__title">[[ siteName ]]</span>
    </a>
</div>
